MCP_URL=http://localhost:3001/mcp
RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── secretKey signing (Steps 6-7) ──────────────────────────────────────────────
# Any funded testnet account that is admin of the contract.
# Example: stellar keys address me  →  TEST_ADMIN_ADDRESS
#          stellar keys show me     →  TEST_SECRET_KEY
TEST_ADMIN_ADDRESS=G...
TEST_SECRET_KEY=S...

# ── PasskeyKit signing (Step 8) ────────────────────────────────────────────────
# Requires a deployed smart wallet contract.  Run:
#   cd testing-devlivables/node-app
#   npx tsx src/deploy-passkey-wallet.ts
# and paste the output below.  Also restart the MCP server with:
#   WALLET_WASM_HASH=<hash> WALLET_SIGNER_SECRET=<secret> ... node dist/index.js
WALLET_CONTRACT_ID=
FEE_PAYER_SECRET=
