# ── Telegram ──────────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram (/newbot)
TELEGRAM_BOT_TOKEN=

# ── MCP Server ────────────────────────────────────────────────────────────────
# Full URL of your running Stellar MCP server
# Test with the Token Factory contract on testnet:
#   MCP_SERVER_URL=https://stellar-mcp-token-factory.vercel.app/mcp
MCP_SERVER_URL=

# Stellar secret key (S...) used to sign write transactions.
# Leave empty for a read-only bot — /call will return unsigned XDR instead.
SIGNER_SECRET=

# Stellar network configuration
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
RPC_URL=https://soroban-testnet.stellar.org

# Mainnet (uncomment to use):
# NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
# RPC_URL=https://mainnet.stellar.validationcloud.io/v1/<YOUR_KEY>

# ── AI Chat Mode (optional) ───────────────────────────────────────────────────
# Set AI_ENABLED=true to enable natural language conversation.
# The bot will use the LLM to understand requests and call contract tools automatically.
#
# Provide ONE of the following API keys:
#   - ANTHROPIC_API_KEY → uses claude-haiku-4-5-20251001 (recommended, faster + cheaper)
#   - OPENAI_API_KEY    → uses gpt-4o
# If both are set, Anthropic takes priority.
AI_ENABLED=false
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Persistent History (optional) ────────────────────────────────────────────
# When a Vercel KV store is linked, conversation history survives cold starts.
# Without KV, history is in-memory and resets on restart (fine for dev).
#
# To enable:
#   1. Vercel Dashboard → Storage → Create KV Database
#   2. Link it to your project — Vercel auto-sets these env vars
#   3. Redeploy. No code changes needed.
#
# KV_REST_API_URL=           # Set automatically by Vercel KV
# KV_REST_API_TOKEN=         # Set automatically by Vercel KV
