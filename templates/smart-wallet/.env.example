# MCP server to connect to (your generated Stellar MCP server)
NEXT_PUBLIC_MCP_SERVER_URL=http://localhost:3001/mcp

# Stellar network
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# PasskeyKit wallet contract WASM hash (deploy once per network, reuse for all wallets)
# Get this from: https://github.com/kalepail/passkey-kit
NEXT_PUBLIC_WALLET_WASM_HASH=<passkey-kit wallet wasm hash>

# Launchtube — sponsors transaction fees so users need no XLM
# Get a JWT from: https://launchtube.xyz
NEXT_PUBLIC_LAUNCHTUBE_URL=https://launchtube.xyz
NEXT_PUBLIC_LAUNCHTUBE_JWT=<your launchtube jwt>
