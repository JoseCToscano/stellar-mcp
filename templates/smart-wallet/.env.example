# ── MCP Server ────────────────────────────────────────────────────────────────
# URL of your generated Stellar MCP server (created via `stellar-mcp generate`)
# This is how the wallet discovers and calls your contract's functions.
NEXT_PUBLIC_MCP_SERVER_URL=http://localhost:3001/mcp

# ── Stellar Network ──────────────────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── PasskeyKit ────────────────────────────────────────────────────────────────
# Smart wallet WASM hash — deploy once per network, reuse for all wallets.
# This testnet hash was built from https://github.com/kalepail/passkey-kit (next branch).
# To deploy your own: cd contracts && make build && make upload
NEXT_PUBLIC_WALLET_WASM_HASH=b3eba29c256a2458faff84fc872226d29df37ad05a6a1c0efe2a95817d6765ec

# ── OpenZeppelin Relayer (fee sponsorship) ────────────────────────────────────
# OZ Relayer sponsors transaction fees so users need no XLM.
# Replaces the deprecated Launchtube service.
# Get a testnet API key: https://channels.openzeppelin.com/testnet/gen
NEXT_PUBLIC_RELAYER_URL=https://channels.openzeppelin.com/testnet
NEXT_PUBLIC_RELAYER_API_KEY=<your-api-key-from-channels.openzeppelin.com/testnet/gen>
