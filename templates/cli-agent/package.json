{
  "name": "stellar-mcp-cli",
  "version": "0.1.0",
  "description": "Terminal agent for Stellar MCP servers",
  "private": true,
  "type": "module",
  "bin": { "stellar-mcp-cli": "dist/index.js" },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@stellar-mcp/client": "^0.1.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@types/node": "^22",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
